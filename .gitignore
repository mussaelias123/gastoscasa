# Configuración local (contiene tokens y ajustes del entorno)
config.json

# Variables de entorno
.env

# Base de datos local (fondo.db desde el rename 2026-07; gastos.db = nombre
# legacy, se mantiene ignorado por si algún entorno todavía no migró)
fondo.db
gastos.db

# Backups automáticos de la DB (no van en Git, son datos)
# backups/ = carpeta de PROD; backupsdev/ = carpeta local de DEV (backup_dir)
backups/
backupsdev/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Entorno virtual
venv/
.venv/
env/

# Build
build/dist/
*.exe

# Worktrees temporales de Claude Code (agentes con isolation)
.claude/worktrees/

# Permisos de Claude Code: por máquina, no se comparte.
# (.claude/agents/ y .claude/launch.json SÍ viajan a propósito — no tocar)
.claude/settings.local.json

# Logs (NSSM AppStdout/AppStderr → logs/, ver docs/CONTEXT_DEPLOY.md)
logs/
